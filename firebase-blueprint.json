{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "pro", "studio"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "isAdmin": { "type": "boolean" }
      },
      "required": ["uid", "email", "plan", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "AI generation project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["video", "voice", "music", "ad", "assistant"] },
        "status": { "type": "string", "enum": ["queued", "processing", "completed", "failed"] },
        "prompt": { "type": "string" },
        "script": { "type": "string" },
        "resultUrl": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "aspectRatio": { "type": "string" },
        "voice": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "isPublic": { "type": "boolean" }
      },
      "required": ["userId", "type", "status", "prompt", "createdAt", "updatedAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A single message in a chat",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Store user profile documents"
    },
    "projects/{projectId}": {
      "schema": "Project",
      "description": "Store AI generation projects"
    },
    "chats/{chatId}": {
      "schema": {
        "type": "object",
        "properties": {
          "userId": { "type": "string" },
          "messages": { "type": "array", "items": { "$ref": "#/entities/ChatMessage" } },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Conversation history"
    }
  }
}
